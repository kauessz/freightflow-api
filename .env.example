# ==================== FreightFlow API — Environment Variables ====================
# Copy this file to .env and fill in the values

# ==================== Server ====================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ==================== Database (PostgreSQL) ====================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=freightflow_dev
DB_USERNAME=freightflow
DB_PASSWORD=freightflow

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== RabbitMQ ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=freightflow
RABBITMQ_PASSWORD=freightflow
RABBITMQ_MGMT_PORT=15672

# ==================== JWT ====================
JWT_SECRET=change-me-in-production-minimum-256-bits-key-here
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_EXPIRATION_MS=604800000

# ==================== CORS ====================
CORS_ORIGINS=http://localhost:3000

# ==================== Stripe (Billing) ====================
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
