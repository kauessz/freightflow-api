# ==================== FreightFlow API — Environment Variables ====================
# Copy this file to .env and fill in the values.
# Railway will inject these automatically when you configure them in the dashboard.

# ==================== Spring Profile ====================
SPRING_PROFILES_ACTIVE=railway

# ==================== Server ====================
PORT=8080

# ==================== Database (PostgreSQL) ====================
# Railway provides these automatically when you add a PostgreSQL plugin:
PGHOST=localhost
PGPORT=5432
PGDATABASE=freightflow
PGUSER=postgres
PGPASSWORD=postgres

# For local dev:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=freightflow_dev
# DB_USERNAME=freightflow
# DB_PASSWORD=freightflow

# ==================== JWT ====================
# IMPORTANT: Use a strong secret (minimum 32 bytes / 256 bits)
# Generate one with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-strong-secret-minimum-32-bytes!!

# Token expiration in milliseconds (default: 24h = 86400000)
JWT_EXPIRATION=86400000

# ==================== CORS ====================
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# ==================== Optional: Redis (for caching/sessions) ====================
# REDIS_URL=redis://default:password@host:port

# ==================== Optional: RabbitMQ (for async events) ====================
# RABBITMQ_URL=amqp://user:password@host:port

# ==================== Optional: Stripe (for billing) ====================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
